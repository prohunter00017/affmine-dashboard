# AffMine Publisher Dashboard — environment variables
# Copy this file to .env and fill in your credentials.
# The .env file is gitignored; never commit real credentials.

# ── Required ────────────────────────────────────────────────
# Your AffMine Affiliate ID (found in the publisher portal)
AFF_ID=your_affiliate_id_here

# Your AffMine API Key (found in the publisher portal)
API_KEY=your_api_key_here

# ── Optional port overrides (defaults shown) ─────────────────
# Dashboard UI  →  http://localhost:3000
DASHBOARD_PORT=3000

# API server    →  http://localhost:5000
API_PORT=5000

# PostgreSQL    →  localhost:5432
POSTGRES_PORT=5432
